# Production service contract. Values stay empty in git.

# Auth.js / application auth
DATABASE_URL=
AUTH_SECRET=
# Canonical site origin ONLY (no path), e.g. https://www.financetracker.dev
AUTH_URL=
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=

# BigQuery / Google Cloud
BIGQUERY_PROJECT_ID=
BIGQUERY_LOCATION=US
GOOGLE_CLOUD_PROJECT=
GOOGLE_CLOUD_CREDENTIALS_JSON=
# Alternative to GOOGLE_CLOUD_CREDENTIALS_JSON:
GOOGLE_CLOUD_CREDENTIALS_BASE64=

# Plaid
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=production
# Use the canonical host; PLAID_REDIRECT_URI must be registered in the Plaid
# Dashboard (Team Settings > API > Allowed redirect URIs) BEFORE deploying, or
# link-token creation fails for every institution. Example:
#   PLAID_WEBHOOK_URL=https://www.financetracker.dev/api/plaid/webhook
#   PLAID_REDIRECT_URI=https://www.financetracker.dev/connections
PLAID_WEBHOOK_URL=
PLAID_REDIRECT_URI=
# Plaid sync runs Dataform automatically by default after it persists rows.
# Set to false to keep warehouse refresh manual.
PLAID_SYNC_REFRESH_WAREHOUSE=true
# Dataform CLI timeout for automatic warehouse refreshes.
WAREHOUSE_REFRESH_TIMEOUT_MS=300000
# Optional override when Dataform credentials are not at dataform/.df-credentials.json.
DATAFORM_CREDENTIALS_FILE=

# Warehouse landing zone
WAREHOUSE_LANDING_BUCKET=
# Alternative to WAREHOUSE_LANDING_BUCKET:
WAREHOUSE_LANDING_URI=

# OpenAI-backed assistant and enrichment
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
OPENAI_CATEGORIZATION_MODEL=gpt-5.2
