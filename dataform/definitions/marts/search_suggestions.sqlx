config {
  type: "view",
  schema: "mart_finance",
  name: "search_suggestions",
  description: "Search index helper for merchant, category, and keyword suggestions.",
  tags: ["mart"]
}

select merchant_raw as label, "merchant" as type
from ${ref("fact_transaction_current")}
group by merchant_raw

union all

select category_label as label, "category" as type
from ${ref("fact_transaction_current")}
group by category_label

union all

select keyword as label, "keyword" as type
from ${ref("fact_transaction_current")},
unnest(keyword_array) as keyword
group by keyword
