config {
  type: "view",
  schema: "mart_finance",
  name: "search_suggestions",
  description: "Search index helper for merchant, category, and keyword suggestions.",
  tags: ["mart"]
}

select user_id, merchant_raw as label, "merchant" as type
from ${ref("fact_transaction_current")}
group by user_id, merchant_raw

union all

select user_id, category_label as label, "category" as type
from ${ref("fact_transaction_current")}
group by user_id, category_label

union all

select user_id, keyword as label, "keyword" as type
from ${ref("fact_transaction_current")},
unnest(keyword_array) as keyword
group by user_id, keyword
