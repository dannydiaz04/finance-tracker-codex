config {
  type: "table",
  schema: "mart_finance",
  name: "daily_cashflow",
  description: "Daily inflow, outflow, and net cash flow excluding internal transfers.",
  tags: ["mart"]
}

select
  user_id,
  posted_at as date,
  sum(
    case
      when direction = "inflow"
        and transaction_class not in ("transfer", "credit_payment")
      then signed_amount
      else 0
    end
  ) as inflow,
  abs(
    sum(
      case
        when direction = "outflow"
          and transaction_class not in ("transfer", "credit_payment")
        then signed_amount
        else 0
      end
    )
  ) as outflow,
  sum(
    case
      when transaction_class not in ("transfer", "credit_payment") then signed_amount
      else 0
    end
  ) as net
from ${ref("fact_transaction_current")}
group by user_id, posted_at
