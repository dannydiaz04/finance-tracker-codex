config {
  type: "table",
  schema: "mart_finance",
  name: "monthly_cashflow",
  description: "Monthly rolled-up cash flow excluding internal transfers.",
  tags: ["mart"]
}

select
  user_id,
  date_trunc(posted_at, month) as month,
  sum(
    case
      when direction = "inflow"
        and transaction_class not in ("transfer", "credit_payment")
      then signed_amount
      else 0
    end
  ) as inflow,
  abs(
    sum(
      case
        when direction = "outflow"
          and transaction_class not in ("transfer", "credit_payment")
        then signed_amount
        else 0
      end
    )
  ) as outflow,
  sum(
    case
      when transaction_class not in ("transfer", "credit_payment") then signed_amount
      else 0
    end
  ) as net
from ${ref("fact_transaction_current")}
group by user_id, month
