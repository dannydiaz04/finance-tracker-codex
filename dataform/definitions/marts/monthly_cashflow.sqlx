config {
  type: "table",
  schema: "mart_finance",
  name: "monthly_cashflow",
  description: "Monthly rolled-up cash flow excluding internal transfers.",
  tags: ["mart"]
}

select
  date_trunc(posted_at, month) as month,
  sum(case when direction = "inflow" and not is_transfer then signed_amount else 0 end) as inflow,
  abs(sum(case when direction = "outflow" and not is_transfer then signed_amount else 0 end)) as outflow,
  sum(case when not is_transfer then signed_amount else 0 end) as net
from ${ref("fact_transaction_current")}
group by month
