config {
  type: "table",
  schema: "analytics_finance",
  name: "transaction_analytics_base",
  description: "Wide analytics-ready transaction base table for descriptive reporting and predictive feature engineering.",
  tags: ["analytics"],
  bigquery: {
    partitionBy: "posted_at",
    clusterBy: ["account_id", "merchant_key", "derived_category_id", "transaction_class"]
  }
}

with history as (
  select
    source_transaction_id,
    account_id,
    count(*) as event_count,
    min(event_timestamp) as first_seen_at,
    max(event_timestamp) as last_seen_at
  from ${ref("fact_transaction_history")}
  group by 1, 2
),
base as (
  select
    staged.transaction_id,
    staged.source_transaction_id,
    staged.canonical_group_id,
    staged.import_batch_id,
    batches.file_name as source_file_name,
    batches.imported_at,
    staged.source_name as source_system,
    staged.event_timestamp as latest_event_timestamp,
    history.event_count,
    history.first_seen_at,
    history.last_seen_at,

    staged.account_id,
    staged.account_name,
    accounts.type as account_type,
    accounts.subtype as account_subtype,
    accounts.institution as institution_name,
    accounts.currency as account_currency_code,
    accounts.mask as account_mask,

    staged.posted_at,
    staged.authorized_at,
    date(staged.authorized_at) as authorized_date,
    date_diff(staged.posted_at, date(staged.authorized_at), day) as auth_to_post_days,
    staged.pending as is_pending,
    staged.signed_amount,
    abs(staged.signed_amount) as amount_abs,
    case
      when staged.signed_amount < 0 then "debit"
      when staged.signed_amount > 0 then "credit"
      else "zero"
    end as debit_credit_indicator,
    staged.direction,
    staged.transaction_class,

    staged.description_raw,
    staged.description_norm,
    staged.merchant_raw,
    staged.merchant_norm,
    coalesce(
      nullif(staged.merchant_norm, ""),
      nullif(staged.description_norm, ""),
      nullif(staged.merchant_raw, ""),
      staged.description_raw
    ) as merchant_key,
    staged.institution_category,

    current.derived_category_id,
    current.category_label,
    current.subcategory_id,
    current.classification_source,
    current.confidence_score,
    current.rule_id,
    current.is_transfer,
    current.is_duplicate,
    coalesce(current.keyword_array, cast([] as array<string>)) as keyword_array,

    coalesce(
      json_value(staged.raw_payload_json, "$.currencyCode"),
      accounts.currency
    ) as transaction_currency_code,
    safe_cast(json_value(staged.raw_payload_json, "$.runningBalance") as numeric) as running_balance,
    safe_cast(json_value(staged.raw_payload_json, "$.availableBalance") as numeric) as available_balance,
    json_value(staged.raw_payload_json, "$.originalDescription") as original_description,
    json_value(staged.raw_payload_json, "$.memo") as memo,
    json_value(staged.raw_payload_json, "$.referenceNumber") as reference_number,
    json_value(staged.raw_payload_json, "$.checkNumber") as check_number,
    json_value(staged.raw_payload_json, "$.transactionType") as transaction_type,
    json_value(staged.raw_payload_json, "$.transactionSubtype") as transaction_subtype,
    json_value(staged.raw_payload_json, "$.paymentChannel") as payment_channel,
    json_value(staged.raw_payload_json, "$.paymentMethod") as payment_method,

    json_value(staged.raw_payload_json, "$.merchantId") as merchant_id,
    json_value(staged.raw_payload_json, "$.merchantCategory") as merchant_category,
    json_value(staged.raw_payload_json, "$.merchantCategoryCode") as merchant_category_code,
    json_value(staged.raw_payload_json, "$.counterpartyName") as counterparty_name,
    json_value(staged.raw_payload_json, "$.counterpartyAccountId") as counterparty_account_id,
    json_value(staged.raw_payload_json, "$.counterpartyType") as counterparty_type,

    json_value(staged.raw_payload_json, "$.merchantCity") as merchant_city,
    json_value(staged.raw_payload_json, "$.merchantState") as merchant_state,
    json_value(staged.raw_payload_json, "$.merchantPostalCode") as merchant_postal_code,
    json_value(staged.raw_payload_json, "$.merchantCountry") as merchant_country,
    safe_cast(json_value(staged.raw_payload_json, "$.latitude") as float64) as latitude,
    safe_cast(json_value(staged.raw_payload_json, "$.longitude") as float64) as longitude,
    json_value(staged.raw_payload_json, "$.deviceType") as device_type,
    json_value(staged.raw_payload_json, "$.onlineOrderId") as online_order_id,

    json_value(staged.raw_payload_json, "$.statementId") as statement_id,
    safe_cast(json_value(staged.raw_payload_json, "$.statementDate") as date) as statement_date,
    json_value(staged.raw_payload_json, "$.recurringGroupId") as recurring_group_id,
    safe_cast(json_value(staged.raw_payload_json, "$.recurringConfidence") as float64) as recurring_confidence,

    staged.raw_payload_json
  from ${ref("transactions_clean")} as staged
  left join ${ref("fact_transaction_current")} as current
    on current.transaction_id = staged.transaction_id
  left join ${ref("dim_account")} as accounts
    on accounts.account_id = staged.account_id
  left join ${ref("import_batches")} as batches
    on batches.import_batch_id = staged.import_batch_id
  left join history
    on history.source_transaction_id = staged.source_transaction_id
   and history.account_id = staged.account_id
)
select
  base.*,

  extract(year from base.posted_at) as posted_year,
  extract(quarter from base.posted_at) as posted_quarter,
  extract(month from base.posted_at) as posted_month,
  extract(isoweek from base.posted_at) as posted_iso_week,
  extract(isoyear from base.posted_at) as posted_iso_year,
  extract(day from base.posted_at) as posted_day_of_month,
  extract(dayofweek from base.posted_at) as posted_day_of_week,
  format_date("%A", base.posted_at) as posted_day_name,
  extract(week(monday) from base.posted_at) as posted_week_monday,
  base.posted_at = last_day(base.posted_at, month) as is_month_end,
  extract(dayofweek from base.posted_at) in (1, 7) as is_weekend,
  case
    when extract(day from base.posted_at) <= 7 then 1
    when extract(day from base.posted_at) <= 14 then 2
    when extract(day from base.posted_at) <= 21 then 3
    when extract(day from base.posted_at) <= 28 then 4
    else 5
  end as week_of_month,

  row_number() over (
    partition by base.account_id
    order by base.posted_at, base.transaction_id
  ) as account_txn_sequence,
  row_number() over (
    partition by base.account_id, base.merchant_key
    order by base.posted_at, base.transaction_id
  ) as merchant_txn_sequence_in_account,
  date_diff(
    base.posted_at,
    lag(base.posted_at) over (
      partition by base.account_id
      order by base.posted_at, base.transaction_id
    ),
    day
  ) as days_since_prior_account_txn,
  date_diff(
    base.posted_at,
    lag(base.posted_at) over (
      partition by base.account_id, base.merchant_key
      order by base.posted_at, base.transaction_id
    ),
    day
  ) as days_since_prior_same_merchant_txn,
  date_diff(
    base.posted_at,
    min(base.posted_at) over (partition by base.account_id),
    day
  ) as account_age_days_at_txn,

  lag(base.signed_amount) over (
    partition by base.account_id
    order by base.posted_at, base.transaction_id
  ) as prior_signed_amount_same_account,
  mod(cast(round(base.amount_abs * 100) as int64), 100) = 0 as is_round_dollar,
  count(*) over (
    partition by base.account_id, base.merchant_key
    order by unix_date(base.posted_at)
    range between 90 preceding and current row
  ) as txn_count_same_merchant_90d,
  avg(base.amount_abs) over (
    partition by base.account_id, base.merchant_key
    order by unix_date(base.posted_at)
    range between 90 preceding and current row
  ) as avg_amount_same_merchant_90d,
  stddev_pop(base.amount_abs) over (
    partition by base.account_id, base.merchant_key
    order by unix_date(base.posted_at)
    range between 90 preceding and current row
  ) as stddev_amount_same_merchant_90d,
  sum(
    case
      when base.signed_amount < 0 then base.amount_abs
      else cast(0 as numeric)
    end
  ) over (
    partition by base.account_id
    order by unix_date(base.posted_at)
    range between 30 preceding and current row
  ) as outflow_30d,
  sum(
    case
      when base.signed_amount > 0 then base.signed_amount
      else cast(0 as numeric)
    end
  ) over (
    partition by base.account_id
    order by unix_date(base.posted_at)
    range between 30 preceding and current row
  ) as inflow_30d
from base
