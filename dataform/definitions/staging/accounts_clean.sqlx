config {
  type: "view",
  schema: "stg_finance",
  name: "accounts_clean",
  description: "Distinct accounts observed in inbound transaction events.",
  tags: ["staging"]
}

select
  account_id,
  any_value(account_name) as name,
  any_value(source_name) as source_name,
  case
    when lower(any_value(account_name)) like "%savings%" then "savings"
    when lower(any_value(account_name)) like "%credit%" then "credit"
    else "checking"
  end as type,
  case
    when lower(any_value(account_name)) like "%savings%" then "high_yield_savings"
    when lower(any_value(account_name)) like "%credit%" then "credit_card"
    else "checking"
  end as subtype,
  "USD" as currency,
  substr(account_id, greatest(length(account_id) - 3, 1), 4) as mask,
  cast(null as numeric) as current_balance,
  cast(null as numeric) as available_balance
from ${ref("transactions_clean")}
group by account_id
