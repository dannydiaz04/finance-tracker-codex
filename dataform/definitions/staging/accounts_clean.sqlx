config {
  type: "view",
  schema: "stg_finance",
  name: "accounts_clean",
  description: "Distinct accounts observed in inbound transaction events.",
  tags: ["staging"]
}

with observed as (
  select
    user_id,
    account_id,
    any_value(account_name) as name,
    any_value(source_name) as source_name
  from ${ref("transactions_clean")}
  group by user_id, account_id
),
metadata as (
  -- Collapse duplicate account_metadata rows to the latest one per account. A
  -- concurrent Plaid-sync MERGE race can insert the same (user_id, account_id)
  -- more than once; without this, the join below fans out the account dimension
  -- and every transaction for that account is duplicated downstream.
  select
    user_id,
    account_id,
    account_name,
    institution,
    account_type,
    account_subtype,
    currency,
    mask,
    current_balance,
    available_balance,
    is_active
  from (
    select
      user_id,
      account_id,
      account_name,
      institution,
      account_type,
      account_subtype,
      currency,
      mask,
      current_balance,
      available_balance,
      is_active,
      row_number() over (
        partition by user_id, account_id
        order by updated_at desc
      ) as metadata_rank
    from ${ref("account_metadata")}
  )
  where metadata_rank = 1
)
select
  coalesce(observed.user_id, metadata.user_id) as user_id,
  coalesce(observed.account_id, metadata.account_id) as account_id,
  coalesce(metadata.account_name, observed.name, metadata.account_id) as name,
  coalesce(metadata.institution, observed.source_name, "Plaid") as source_name,
  coalesce(
    metadata.account_type,
    case
      when lower(observed.name) like "%savings%" then "savings"
      when lower(observed.name) like "%credit%" then "credit"
      when lower(observed.name) like "%card%" then "credit"
      else "checking"
    end
  ) as type,
  coalesce(
    metadata.account_subtype,
    case
      when lower(observed.name) like "%savings%" then "high_yield_savings"
      when lower(observed.name) like "%credit%" then "credit_card"
      when lower(observed.name) like "%card%" then "credit_card"
      else "checking"
    end
  ) as subtype,
  coalesce(metadata.currency, "USD") as currency,
  coalesce(
    nullif(metadata.mask, ""),
    regexp_extract(observed.account_id, r"([0-9]{4})$"),
    "unknown"
  ) as mask,
  metadata.current_balance as current_balance,
  metadata.available_balance as available_balance
from observed
full outer join metadata
  on metadata.account_id = observed.account_id
 and metadata.user_id = observed.user_id
 and coalesce(metadata.is_active, true)
where observed.account_id is not null
   or coalesce(metadata.is_active, true)
