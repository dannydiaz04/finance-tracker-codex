config {
  type: "view",
  schema: "ops_finance",
  name: "ai_enrichment_queue",
  description: "Posted transactions that are good candidates for OpenAI-powered merchant standardization and category suggestions.",
  tags: ["ops", "ai"]
}

select
  user_id,
  transaction_id,
  account_id,
  account_name,
  posted_at,
  signed_amount,
  merchant_raw,
  merchant_norm,
  description_raw,
  description_norm,
  institution_category,
  -- Plaid's machine-learning categorization, surfaced as a strong prior for the
  -- LLM categorizer. `institution_category` already carries PFC primary; pull the
  -- finer-grained detailed label and Plaid's own confidence level out of the raw
  -- Plaid transaction, which is nested under `$.rawPayloadJson` inside the event
  -- payload (null for CSV-imported rows, which simply yields no prior).
  json_value(raw_payload_json, "$.rawPayloadJson.personal_finance_category.detailed")
    as institution_category_detailed,
  json_value(raw_payload_json, "$.rawPayloadJson.personal_finance_category.confidence_level")
    as institution_category_confidence,
  derived_category_id,
  category_label,
  transaction_class,
  classification_source,
  confidence_score,
  keyword_array,
  raw_payload_json,
  case
    when derived_category_id = "uncategorized" then "No deterministic category matched."
    when classification_source = "institution_category" then "Only institution-provided category is available."
    when confidence_score < 0.85 then "Low-confidence classification."
    else "Merchant standardization review."
  end as enrichment_reason
from ${ref("fact_transaction_current")}
where not pending
  and transaction_class not in ("transfer", "credit_payment")
  and (
    derived_category_id = "uncategorized"
    or classification_source = "institution_category"
    or confidence_score < 0.85
  )
