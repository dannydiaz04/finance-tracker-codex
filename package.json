{
  "name": "finance-tracker-codex",
  "version": "0.1.0",
  "private": true,
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "etl:dropbox": "bash scripts/process-dropbox.sh",
    "etl:runner": "node --conditions=react-server --experimental-strip-types scripts/run-landed-imports.ts",
    "etl:ai-enrich": "node --conditions=react-server --experimental-strip-types scripts/run-ai-enrichment.ts",
    "test:imports": "node --conditions=react-server --experimental-strip-types --test tests/import/*.test.mjs",
    "typecheck": "tsc --noEmit",
    "dataform:compile": "dataform compile dataform",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push"
  },
  "dependencies": {
    "@auth/drizzle-adapter": "^1.11.2",
    "@google-cloud/bigquery": "^8.1.1",
    "@google-cloud/storage": "^7.19.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "drizzle-orm": "^0.45.2",
    "lucide-react": "^1.7.0",
    "motion": "^12.38.0",
    "next": "16.2.9",
    "next-auth": "^5.0.0-beta.31",
    "papaparse": "^5.5.3",
    "pg": "^8.21.0",
    "plaid": "^42.2.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-plaid-link": "^4.1.1",
    "server-only": "^0.0.1",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@dataform/cli": "^3.0.59",
    "@dataform/core": "^3.0.50",
    "@tailwindcss/postcss": "^4",
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20",
    "@types/papaparse": "^5.5.2",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "typescript": "^5"
  },
  "overrides": {
    "next": {
      "postcss": "8.5.10"
    },
    "uuid": "11.1.1"
  }
}
